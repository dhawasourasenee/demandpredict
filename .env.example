# API (apps/api)
DATABASE_URL=sqlite:///./fashion_calc.db
ANTHROPIC_API_KEY=
# Optional; no remote Apify/MCP in this build (Claude Messages API only).
# APIFY_TOKEN=
# APIFY_MCP_URL=
LOG_LEVEL=INFO

# Web (apps/web) — Vite prefix (set in Vercel to your deployed API origin)
VITE_API_URL=http://127.0.0.1:8000

# API: browser origins allowed to call the API (add your *.vercel.app and custom domain)
# CORS_ORIGINS=https://your-app.vercel.app,https://www.yourdomain.com
