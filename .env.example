# Python API (api/) — local: npm run dev:api from repo root; needs venv + pip install -r api/requirements.txt
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
# Optional extra CORS origins (comma-separated) for production if frontend is on another domain
# CORS_ORIGINS=https://your-app.vercel.app

# Frontend (Vite) — leave empty when API is same origin (Vercel) or proxied in dev (/api -> :8000)
# VITE_API_BASE=https://your-api-host.example.com
