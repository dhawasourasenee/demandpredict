# OpenAI — browser calls (see security note below)
VITE_OPENAI_API_KEY=
# Vision-capable model, e.g. gpt-4o, gpt-4o-mini
VITE_OPENAI_MODEL=gpt-4o

# SECURITY: VITE_* vars are embedded in the client bundle. Anyone can extract
# your key from the built app. Use this only for local demos; for production,
# proxy requests through your own backend or use a worker with a secret.
