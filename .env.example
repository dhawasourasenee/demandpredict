# Python API — local: python3 -m venv api/.venv && api/.venv/bin/pip install -r requirements.txt && npm run dev:api
OPENAI_API_KEY=
# Use a Responses API model that supports vision + hosted web_search (e.g. gpt-4.1, gpt-4.1-mini, gpt-5.x).
OPENAI_MODEL=gpt-4.1
# Optional extra CORS origins (comma-separated) for production if frontend is on another domain
# CORS_ORIGINS=https://your-app.vercel.app

# Frontend (Vite) — leave empty when API is same origin (Vercel) or proxied in dev (/api -> :8000)
# VITE_API_BASE=https://your-api-host.example.com
